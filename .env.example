# .env.example — variables liées au SEO / Search Console.
# Copier en .env.local et remplir. NE JAMAIS commiter .env.local (cf .gitignore).
# Pour les variables applicatives (Resend, Mistral...), voir .env.local.example.

# URL de production du site (sans slash final). Sert aux URL absolues / canonical.
NEXT_PUBLIC_SITE_URL=https://www.sm-depannage59.fr

# Code de vérification Google Search Console (balise meta google-site-verification).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Rapport Search Console (scripts/search-console-report.mjs) ───────────────
# Propriété GSC : sc-domain:sm-depannage59.fr  ou  https://www.sm-depannage59.fr/
GSC_SITE_URL=sc-domain:sm-depannage59.fr
# Compte de service Google Cloud avec accès LECTURE à la propriété GSC.
GOOGLE_CLIENT_EMAIL=
# Clé privée du compte de service (les \n peuvent rester échappés).
GOOGLE_PRIVATE_KEY=
