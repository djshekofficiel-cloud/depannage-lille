# Variables d'environnement — copier ce fichier en .env.local et remplir les valeurs
# IMPORTANT : .env.local ne doit JAMAIS être commité (il est dans .gitignore)

# ── Resend (envoi des emails du formulaire de contact) ────────────────────────
# Créer un compte sur https://resend.com, vérifier votre domaine, puis copier la clé
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email qui reçoit les demandes d'intervention
CONTACT_EMAIL=contact@votredomaine.fr

# ── URL du site (utilisé pour les métadonnées Open Graph) ────────────────────
NEXT_PUBLIC_SITE_URL=https://votredomaine.fr

# ── Numéro de téléphone affiché (format international) ───────────────────────
NEXT_PUBLIC_PHONE=+33XXXXXXXXX

# ── Analytics Plausible (optionnel — sans cookie) ─────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=votredomaine.fr
